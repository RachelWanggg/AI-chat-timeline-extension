{
  "manifest_version": 3,
  "name": "AI Chat Timeline",
  "version": "0.1.0",
  "description": "Adds structured timeline navigation to AI chat interfaces.",

  "icons": {
    "128": "icons/icon.jpeg"
  },

  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://api.anthropic.com/*"
  ],

  "action": {
    "default_title": "Open AI Timeline"
  },

  "side_panel": {
    "default_path": "panel/sidepanel.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}