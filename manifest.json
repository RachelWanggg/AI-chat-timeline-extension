{
  "manifest_version": 3,
  "name": "AI Chat Timeline",
  "version": "0.2.2",
  "description": "Adds structured timeline navigation to AI chat interfaces, works on ChatGPT and Claude.ai",
  "icons": {
    "128": "icons/icon.jpeg"
  },
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_title": "Open AI Timeline"
  },
  "side_panel": {
    "default_path": "panel/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  
  "web_accessible_resources": [
    {
      "resources": [
        "content/*",
        "content/adapters/*",
        "content/ui/*",
        "content/state/*",
        "content/timeline/*",
        "content/revise/*",
        "content/utils/*"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ]
    }
  ],
  
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}