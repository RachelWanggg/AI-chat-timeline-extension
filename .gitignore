# ========================
node_modules/
package-lock.json   # 如果用 yarn 管理，可以忽略这个
yarn.lock           # 如果用 npm 管理，可以忽略这个

# ========================
# 构建产物 (Build Output)
# ========================
dist/
build/
*.zip               # 打包好的 extension zip

